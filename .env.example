# Global (renderer/web/api)
CONTENT_DIR=/content
MUSIC_DIR=/content/audio/music
OUTPUT_DIR=/output
TMP_DIR=/tmp/renderer
REMOTE_ASSET_CACHE_DIR=/content/cache/remote-assets
LOG_LEVEL=info
JSON_LOGS=true
DEBUG=false
JOB_TIMEOUT_SEC=900
MAX_CONCURRENT=2
MAX_CLAIM=1
POLL_INTERVAL_MS=5000
LEASE_SECONDS=180
HEARTBEAT_INTERVAL_SEC=10

# Database / compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=darklife
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/darklife
REDIS_URL=redis://redis:6379/0

# API access
API_BASE_URL=http://api:8000
PUBLIC_BASE_URL=http://localhost:8000
API_AUTH_TOKEN=
ARTIFACT_SIGNING_SECRET=
PIXABAY_API_KEY=

# TTS
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TTS_CACHE_DIR=/content/tts_cache
TTS_RATE_LIMIT_RPS=3
TTS_SPEAKING_STYLE=0
TTS_SPEAKING_SPEED=1.0
XTTS_MODEL_DIR=/opt/xtts/model
XTTS_CHECKPOINT_GLOB=best_model*.pth
XTTS_WORKSPACE_DIR=/opt/xtts
XTTS_RUN_DIR=
XTTS_CHECKPOINT_PATH=
XTTS_CONFIG_PATH=
XTTS_VOCAB_PATH=
XTTS_SPEAKER_FILE_PATH=
XTTS_SPEAKER_WAV=/opt/xtts/reference/your-speaker.wav
XTTS_LANGUAGE=en
XTTS_DEVICE=cpu
XTTS_MOUNT_ROOT=

# Whisper ASR
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_PROVIDER=local
SUBTITLES_FORMAT=srt
SUBTITLES_BURN_IN=false
OPENAI_API_KEY=
OPENAI_SCRIPT_MODEL=gpt-4.1-mini

# Web (Next.js)
# Set this to the same value as API_AUTH_TOKEN.
VITE_CLERK_ENABLED=true
ADMIN_API_TOKEN=

# Reddit ingestion
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=darklife/1.0
REDDIT_DEFAULT_SUBREDDITS=Odd_directions,shortscarystories,nosleep,stayawake,Ruleshorror,libraryofshadows,JustNotRight,TheCrypticCompendium,SignalHorrorFiction,scarystories,SLEEPSPELL,TwoSentenceHorror
BACKFILL_USE_CLOUDSEARCH=false
BACKFILL_MAX_PAGES=12
DEBUG_INGEST_SAMPLE=false

# Scheduler
SCHEDULER_INTERVAL_SEC=3600
SCHEDULER_ENABLE_REDDIT=false
SCHEDULER_ENABLE_APPROVED_SHORTS=false
SCHEDULER_ENABLE_WEEKLY=true

# Publisher
PUBLISH_POLL_INTERVAL_SEC=15
PUBLISH_MAX_CONCURRENT=1
PUBLISH_LEASE_SECONDS=180
PUBLISH_RETRY_LIMIT=3
ACTIVE_PUBLISH_PLATFORMS=youtube
SHORTS_PUBLISH_SLOTS_UTC=08:00,13:00,18:00
SHORTS_PUBLISH_HOUR_UTC=12
SHORTS_PUBLISH_MINUTE_UTC=0
EARLY_SIGNAL_WINDOW_HOURS=4
WEEKLY_COMPILATION_DAY_UTC=4
WEEKLY_COMPILATION_HOUR_UTC=12
WEEKLY_COMPILATION_MINUTE_UTC=0

# Uploads
YOUTUBE_CLIENT_SECRETS_FILE=/secrets/client_secret.json
YOUTUBE_TOKEN_FILE=/secrets/token.json
INSTAGRAM_GRAPH_API_BASE=https://graph.facebook.com/v23.0
INSTAGRAM_APP_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
