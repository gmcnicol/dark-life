# Global (renderer/web/api)
CONTENT_DIR=/content
MUSIC_DIR=/content/audio/music
OUTPUT_DIR=/output
TMP_DIR=/tmp/renderer
LOG_LEVEL=info
JSON_LOGS=true
DEBUG=false
JOB_TIMEOUT_SEC=900
MAX_CONCURRENT=2
MAX_CLAIM=1
POLL_INTERVAL_MS=5000
LEASE_SECONDS=180

# Database / compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=darklife
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/darklife
REDIS_URL=redis://redis:6379/0

# API access
API_BASE_URL=http://api:8000
API_AUTH_TOKEN=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TTS_CACHE_DIR=/content/tts_cache
TTS_RATE_LIMIT_RPS=3
TTS_SPEAKING_STYLE=0
TTS_SPEAKING_SPEED=1.0

# Whisper ASR
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
SUBTITLES_FORMAT=srt
SUBTITLES_BURN_IN=false
OPENAI_API_KEY=
OPENAI_SCRIPT_MODEL=gpt-4.1-mini

# Web (Next.js)
# Set this to the same value as API_AUTH_TOKEN.
ADMIN_API_TOKEN=

# Reddit ingestion
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=darklife/1.0
REDDIT_DEFAULT_SUBREDDITS=nosleep,confession,TrueOffMyChest
BACKFILL_USE_CLOUDSEARCH=false
BACKFILL_MAX_PAGES=12
DEBUG_INGEST_SAMPLE=false

# Scheduler
SCHEDULER_INTERVAL_SEC=3600
SCHEDULER_ENABLE_REDDIT=true
SCHEDULER_ENABLE_WEEKLY=true

# Uploads
YOUTUBE_CLIENT_SECRETS_FILE=/secrets/client_secret.json
YOUTUBE_TOKEN_FILE=/secrets/token.json
